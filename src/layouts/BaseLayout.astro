---
export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  article?: boolean;
  publishDate?: Date;
}

const {
  title,
  description = 'AI strategist and thought leader helping organizations transform with intelligent automation.',
  ogImage = '/og-default.png',
  article = false,
  publishDate,
} = Astro.props;

const siteUrl = 'https://ketchcyork.github.io';
const canonicalURL = new URL(Astro.url.pathname, siteUrl);
const fullTitle = title === 'Home' ? 'C. York — AI Strategist & Thought Leader' : `${title} | C. York`;
---

<!doctype html>
<html lang="en" class="bg-gray-950 text-gray-100 scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Primary Meta Tags -->
    <title>{fullTitle}</title>
    <meta name="title" content={fullTitle} />
    <meta name="description" content={description} />
    <meta name="author" content="C. York" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={article ? 'article' : 'website'} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, siteUrl)} />
    {article && publishDate && <meta property="article:published_time" content={publishDate.toISOString()} />}

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={fullTitle} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL(ogImage, siteUrl)} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

    <!-- RSS -->
    <link rel="alternate" type="application/rss+xml" title="C. York Blog" href="/rss.xml" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="min-h-screen flex flex-col antialiased">
    <!-- Nav -->
    <header class="sticky top-0 z-50 border-b border-gray-800/60 bg-gray-950/80 backdrop-blur-md">
      <nav class="mx-auto max-w-4xl px-4 sm:px-6 flex items-center justify-between h-16">
        <a href="/" class="font-semibold text-white hover:text-accent transition-colors tracking-tight">
          C. York
        </a>
        <div class="flex items-center gap-6 text-sm font-medium text-gray-400">
          <a href="/about" class="hover:text-white transition-colors">About</a>
          <a href="/blog" class="hover:text-white transition-colors">Blog</a>
          <a href="/contact" class="hover:text-white transition-colors">Contact</a>
        </div>
      </nav>
    </header>

    <!-- Main -->
    <main class="flex-1">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-gray-800/60 py-10 mt-20">
      <div class="mx-auto max-w-4xl px-4 sm:px-6 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-gray-500">
        <p>&copy; {new Date().getFullYear()} C. York. All rights reserved.</p>
        <div class="flex items-center gap-5">
          <a href="/blog" class="hover:text-gray-300 transition-colors">Blog</a>
          <a href="/rss.xml" class="hover:text-gray-300 transition-colors">RSS</a>
          <a href="https://linkedin.com/in/cyork" class="hover:text-gray-300 transition-colors" target="_blank" rel="noopener">LinkedIn</a>
        </div>
      </div>
    </footer>
  </body>
</html>
