---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<BaseLayout
  title="Blog"
  description="Writing on AI strategy, organizational transformation, and the future of intelligent automation."
>
  <div class="mx-auto max-w-3xl px-4 sm:px-6 py-16">
    <p class="text-accent font-mono text-sm mb-3 tracking-wide">Writing</p>
    <h1 class="text-4xl font-bold text-white mb-3">Blog</h1>
    <p class="text-gray-400 text-lg mb-12">
      Thoughts on AI strategy, organizational change, and building with intelligence.
    </p>

    {posts.length === 0 ? (
      <div class="border border-gray-800 rounded-xl p-10 text-center">
        <p class="text-gray-500">First post coming soon.</p>
      </div>
    ) : (
      <div class="space-y-8">
        {posts.map((post) => (
          <article class="group">
            <a href={`/blog/${post.slug}`} class="block border border-gray-800 rounded-xl p-6 hover:border-accent/50 transition-colors bg-gray-900/20 hover:bg-gray-900/40">
              <div class="flex items-center gap-3 mb-3">
                <time class="text-xs text-gray-500 font-mono" datetime={post.data.pubDate.toISOString()}>
                  {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                </time>
                {post.data.tags && post.data.tags.slice(0, 2).map((tag: string) => (
                  <span class="text-xs bg-gray-800 text-gray-400 px-2 py-0.5 rounded-full">{tag}</span>
                ))}
              </div>
              <h2 class="text-xl font-semibold text-gray-100 group-hover:text-accent transition-colors mb-2">
                {post.data.title}
              </h2>
              <p class="text-gray-400 text-sm leading-relaxed">{post.data.description}</p>
              <span class="inline-block mt-4 text-sm text-accent">Read more →</span>
            </a>
          </article>
        ))}
      </div>
    )}
  </div>
</BaseLayout>
